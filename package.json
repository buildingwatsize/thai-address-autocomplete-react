{
  "name": "thai-address-autocomplete-react",
  "version": "2.0.0",
  "type": "module",
  "author": "buildingwatsize (Chinnawat Chimdee)",
  "keywords": [
    "react",
    "typescript",
    "library",
    "components",
    "input",
    "auto-complete",
    "thai",
    "addresses",
    "thai-address-autocomplete-react",
    "tailwind",
    "headless",
    "hooks"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc --p ./tsconfig.build.json && vite build",
    "lint": "eslint lib --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publish": "yarn build && npm publish",
    "example-lint": "cd ./example && yarn run lint",
    "example-initial": "yarn install && yarn run build",
    "example-build": "cd ./example && yarn install && yarn run build",
    "example-preview": "cd ./example && yarn preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ]
}
