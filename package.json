{
  "name": "thai-address-autocomplete-react",
  "version": "1.2.3",
  "type": "module",
  "author": "buildingwatsize (Chinnawat Chimdee)",
  "keywords": [
    "react",
    "typescript",
    "library",
    "components",
    "input",
    "auto-complete",
    "thai",
    "addresses",
    "thai-address-autocomplete-react"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc --p ./tsconfig.build.json && vite build",
    "lint": "eslint lib --report-unused-disable-directives --max-warnings 0",
    "publish": "yarn build && npm publish",
    "example-lint": "cd ./example && yarn run lint",
    "example-initial": "yarn install && yarn run build",
    "example-build": "cd ./example && yarn install && yarn run build",
    "example-preview": "cd ./example && yarn preview"
  },
  "peerDependencies": {
    "antd": "^5.0.0 || ^6.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ]
